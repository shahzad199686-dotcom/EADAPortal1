@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Environment Audit Designated Agency (EADA) - Precise Reference Branding" />
    <title>EADA | Environment Audit Designated Agency</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">

    <style>
        :root {
            --forest-green: #0b6623;
            --forest-green-dark: #005a2b;
            --accent-yellow: #f59e0b;
            --text-dark: #1f2937;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --container-w: 1280px;
            --hero-bg: #4b4b4b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; color: var(--text-dark); background: #fdfdfd; line-height: 1.5; overflow-x: hidden; }
        
        h1, h2, h3, .serif { font-family: 'Playfair Display', serif; }
        
        .container { max-width: var(--container-w); margin: 0 auto; padding: 0 1.5rem; }
        .flex-between { display: flex; justify-content: space-between; align-items: center; }

        /* --- 1. Top Government Identity --- */
        .gov-strip {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0.3rem 0;
            font-size: 0.75rem;
            font-weight: 600;
            color: #1f2937;
        }
        .gov-strip-inner { display: flex; justify-content: space-between; align-items: center; }
        .gov-left { display: flex; align-items: center; gap: 0.75rem; }
        .flag-box { width: 18px; height: 12px; border: 1px solid #ddd; background: linear-gradient(#FF9933 33.3%, #ffffff 33.3% 66.6%, #128807 66.6%); }

        /* --- 2. Branding Strip --- */
        .branding-strip {
            padding: 1rem 0;
            background: #ffffff;
            border-bottom: 1px solid #eee;
        }
        .branding-inner { display: flex; justify-content: space-between; align-items: center; }
        .brand-logos-left { display: flex; align-items: center; gap: 1rem; }
        .logo-group { display: flex; align-items: center; gap: 0.75rem; }
        .brand-titles { text-align: left; margin-left: 0.5rem; }
        .brand-titles h1 { font-size: 1.85rem; font-weight: 900; color: #1f2937; line-height: 1; letter-spacing: -0.01em; }
        .brand-titles p { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-top: 4px; }

        .brand-right { display: flex; align-items: center; gap: 1.5rem; }
        .badge-logo, .mini-logo { position: relative; display: flex; align-items: center; justify-content: center; }
        .mini-logo { width: 52px; height: 52px; }
        .badge-logo { height: 42px; min-width: 65px; }

        .badge-logo:not(:last-child)::after {
            content: ''; position: absolute; right: -0.75rem; top: 50%; transform: translateY(-50%); height: 75%; width: 1px; background-color: #cbd5e1;
        }
        
        .badge-logo img, .mini-logo img { max-height: 100%; max-width: 100%; object-fit: contain; }

        .util-dropdown {
            background: #004a99; color: white; padding: 0.4rem 0.8rem; border-radius: 4px;
            font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 8px; cursor: pointer;
        }

        /* --- 3. Navigation Bar --- */
        .navbar-wrap { background: var(--forest-green-dark); }
        .nav-inner { display: flex; justify-content: space-between; align-items: center; height: 52px; }
        .nav-links { display: flex; list-style: none; gap: 1.5rem; align-items: center; }
        .nav-link { text-decoration: none; color: #ffffff; font-size: 0.9rem; font-weight: 600; transition: 0.2s; }
        .nav-link:hover { opacity: 0.8; }

        .nav-item-dropdown { position: relative; }
        .dropdown-menu {
            display: none; position: absolute; top: 100%; left: 0; background: #ffffff; min-width: 280px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-radius: 4px; border: 1px solid #e5e7eb; padding: 0.5rem 0; z-index: 100;
        }
        .nav-item-dropdown:hover .dropdown-menu { display: block; }
        .dropdown-item { display: block; padding: 0.75rem 1.25rem; color: #1f2937; text-decoration: none; font-size: 0.85rem; font-weight: 600; text-align: left; }
        .dropdown-item:hover { background: #f0fdf4; color: var(--forest-green-dark); }

        /* --- 4. Notice Strip --- */
        .notice-strip { display: flex; align-items: center; background: #e0f2fe; border-bottom: 1px solid #bae6fd; font-size: 0.85rem; height: 38px; overflow: hidden; }
        .notice-badge { background: #0284c7; color: white; padding: 0 1.25rem; height: 100%; display: flex; align-items: center; font-weight: 800; font-size: 0.75rem; position: relative; z-index: 2; }
        .notice-badge::after { content:''; position: absolute; right: -10px; top:0; width:0; height:0; border-top: 19px solid transparent; border-bottom: 19px solid transparent; border-left: 10px solid #0284c7; }
        .marquee-container { flex: 1; overflow: hidden; height: 100%; display: flex; align-items: center; }
        .marquee-text { white-space: nowrap; color: #0f172a; font-weight: 600; animation: marquee 25s linear infinite; padding-left: 100%; }
        @@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-100%); } }

        /* --- 5. Hero Section --- */
        .hero { display: grid; grid-template-columns: 55% 45%; min-height: 520px; width: 100%; }
        .hero-left { position: relative; overflow: hidden; background: #f1f5f9; }
        .hero-slider { position: absolute; inset: 0; }
        .hero-slide { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0; transition: opacity 1.2s ease; }
        .hero-slide.active { opacity: 1; z-index: 2; }
        .slide-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.15), transparent); z-index: 3; }
        .slider-nav { position: absolute; top: 50%; width: 100%; display: flex; justify-content: space-between; padding: 0 1.5rem; transform: translateY(-50%); z-index: 10; pointer-events: none; }
        .nav-btn { width: 44px; height: 44px; background: rgba(255,255,255,0.2); backdrop-filter: blur(4px); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; border: 1px solid rgba(255,255,255,0.3); cursor: pointer; pointer-events: auto; }

        .hero-right { background: #ffffff; display: flex; align-items: center; justify-content: center; padding: 3rem; }
        .eada-logo-minimal img { width: 280px; height: auto; max-width: 90%; }

        /* --- 6. Modules Section (Pills) --- */
        .modules-section { padding: 4rem 0 6rem; background: #ffffff; }
        .mod-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; justify-content: center; }
        .mod-pill-card { 
            background: #eaf7ee; border: 1px solid #d1ead9; border-radius: 100px; padding: 1.2rem 2.5rem 1.2rem 1.2rem;
            display: flex; align-items: center; gap: 1.5rem; transition: 0.4s ease; text-decoration: none; position: relative;
        }
        .mod-pill-card:hover { transform: translateY(-5px); box-shadow: 0 12px 25px rgba(0, 74, 55, 0.08); background: #ffffff; border-color: var(--forest-green); }
        .mod-icon-box { width: 72px; height: 72px; background: #ffffff; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--forest-green-dark); }
        .mod-icon-box svg { width: 32px; height: 32px; }
        .mod-title { font-size: 1.15rem; font-weight: 800; color: var(--text-dark); margin-bottom: 2px; position: relative; }
        .mod-title::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 40px; height: 2px; background: var(--forest-green); opacity: 0.6; }
        .mod-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; margin-top: 6px; }
        .mod-status-tag { position: absolute; top: -10px; right: 40px; background: #ffffff; border: 1px solid var(--forest-green); color: var(--forest-green-dark); padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; }

        /* --- 7. About Section (Modern Split) --- */
        .about-section { padding: 8rem 0; background: #ffffff; position: relative; overflow: hidden; }
        .about-section::before {
            content: ''; position: absolute; top: 0; right: 0; width: 45%; height: 100%;
            background: linear-gradient(135deg, rgba(234, 247, 238, 0.8) 0%, rgba(13, 102, 35, 0.15) 100%);
            clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 0% 100%); z-index: 1;
        }
        .about-split { display: flex; align-items: center; gap: 6rem; position: relative; z-index: 2; }
        .about-left { flex: 0 0 420px; max-width: 420px; }
        .about-image-wrap { box-shadow: 20px 20px 60px rgba(0,0,0,0.08); border-radius: 4px; overflow: hidden; }
        .about-image-wrap img { width: 100%; transition: 0.6s ease; }
        .about-image-wrap:hover img { transform: scale(1.05); }
        .about-right { flex: 1; }
        .about-label-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
        .about-label { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-muted); }
        .about-divider { width: 60px; height: 1.5px; background: var(--text-dark); }
        .about-title { font-size: 3.5rem; font-weight: 900; line-height: 1.1; color: var(--text-dark); text-transform: uppercase; margin-bottom: 2.5rem; letter-spacing: -0.02em; }
        .about-content-body p { font-size: 1.05rem; line-height: 1.8; color: var(--text-dark); margin-bottom: 2rem; opacity: 0.85; }
        .about-btn { display: inline-block; padding: 1.2rem 3rem; border: 2px solid var(--text-dark); text-transform: uppercase; font-size: 0.85rem; font-weight: 800; color: var(--text-dark); text-decoration: none; transition: 0.3s ease; }
        .about-btn:hover { background: var(--text-dark); color: #ffffff; transform: translateX(10px); }

        /* --- Footer --- */
        footer { background: #012a14; color: white; padding: 5rem 0 3rem; }

        /* Responsiveness */
        @@media (max-width: 1024px) {
            .hero { grid-template-columns: 1fr; }
            .hero-right { padding: 2rem; }
            .about-split { flex-direction: column; gap: 4rem; }
            .about-left { max-width: 100%; flex: none; }
            .about-section::before { width: 100%; height: 40%; top: auto; bottom: 0; clip-path: polygon(0% 25%, 100% 0%, 100% 100%, 0% 100%); }
            .mod-grid { grid-template-columns: 1fr; max-width: 600px; margin: 0 auto; }
            .about-title { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <div class="gov-strip">
        <div class="container gov-strip-inner">
            <div class="gov-left">
                <div class="flag-box"></div>
                <span>भारत सरकार | Government of India</span>
            </div>
            <div class="brand-right" style="gap: 1rem;">
                <span style="border-right: 1px solid #ccc; padding-right: 10px;">A- A A+</span>
                <div class="util-dropdown">EN ▾</div>
            </div>
        </div>
    </div>

    <div class="branding-strip">
        <div class="container branding-inner">
            <div class="brand-logos-left">
                <div class="logo-group">
                    <div class="mini-logo"><img src="/images/branding/logo_emblem.png" alt="Emblem" /></div>
                    <div class="mini-logo"><img src="/images/branding/logo_eada.png" alt="EADA" /></div>
                </div>
                <div class="brand-titles">
                    <h1>EADA</h1>
                    <p>Environment Audit Designated Agency</p>
                </div>
            </div>
            <div class="brand-right">
                <div class="badge-logo"><img src="/images/branding/logo_azadi.png" alt="Azadi" /></div>
                <div class="badge-logo"><img src="/images/branding/logo_life.png" alt="LiFE" /></div>
                <a href="https://www.npcindia.gov.in/NPC/User/index" target="_blank" class="badge-logo"><img src="/images/branding/logo_npc.png" alt="NPC" /></a>
            </div>
        </div>
    </div>

    <nav class="navbar-wrap">
        <div class="container nav-inner">
            <ul class="nav-links">
                <li><a href="#" class="nav-link">Home</a></li>
                <li><a href="#" class="nav-link">About EADA</a></li>
                <li><a href="https://static.pib.gov.in/WriteReadData/specificdocs/documents/2025/sep/doc202593627401.pdf" target="_blank" class="nav-link">Rules</a></li>
                <li class="nav-item-dropdown">
                    <a href="#" class="nav-link">Guidelines ▾</a>
                    <div class="dropdown-menu">
                        <a href="~/docs/guideline for cea through rpl.pdf" target="_blank" class="dropdown-item">Guideline for CEA through RPL</a>
                        <a href="~/docs/guideline for rea.pdf" target="_blank" class="dropdown-item">Guideline for REA</a>
                    </div>
                </li>
                <li><a href="#" class="nav-link">Contact</a></li>
            </ul>
        </div>
    </nav>

    <div class="notice-strip">
        <div class="notice-badge">Latest Update</div>
        <div class="marquee-container">
            <div class="marquee-text">The Environment Audit Designated Agency (EADA) under the Environment Audit Rules, 2025 is now live. | Apply for EC/FC/WL/CRZ via the official portal framework.</div>
        </div>
    </div>

    <section class="hero">
        <div class="hero-left">
            <div class="hero-slider">
                <div class="hero-slide active" style="background-image: url('/images/branding/hero_banner.jpg');">
                    <div class="slide-overlay"></div>
                </div>
            </div>
        </div>
        <div class="hero-right">
            <div class="eada-logo-minimal"><img src="/images/branding/logo_eada.png" alt="EADA Logo" /></div>
        </div>
    </section>

    <section class="modules-section">
        <div class="container">
            <div class="mod-grid">
                <article class="mod-pill-card">
                    <div class="mod-status-tag">Coming Soon</div>
                    <div class="mod-icon-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle><path d="M12 11h.01"></path><path d="M11 7h2"></path><path d="M11 15h2"></path><path d="M11 19h2"></path>
                        </svg>
                    </div>
                    <div class="mod-content">
                        <h3 class="mod-title">Recognition of Prior Learning (CEA RPL)</h3>
                        <p class="mod-desc">A dedicated portal for existing environmental professionals to certify their expertise and align with the EADA framework.</p>
                    </div>
                </article>
                <article class="mod-pill-card">
                    <div class="mod-status-tag">Coming Soon</div>
                    <div class="mod-icon-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    <div class="mod-content">
                        <h3 class="mod-title">Registered Environmental Auditor (REA)</h3>
                        <p class="mod-desc">Official registry and auditing management system for environmental compliance monitoring across industrial sectors.</p>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="about-section">
        <div class="container">
            <div class="about-split">
                <div class="about-left">
                    <div class="about-image-wrap"><img src="/images/branding/about_building.jpg" alt="EADA Building" /></div>
                </div>
                <div class="about-right">
                    <div class="about-label-row"><span class="about-label">Who We Are</span><div class="about-divider"></div></div>
                    <h2 class="about-title">About Environment Audit Designated Agency</h2>
                    <div class="about-content-body">
                        <p>The Environment Audit Designated Agency (EADA) is a role established under the Environment Audit Rules, 2025 by the Ministry of Environment, Forest and Climate Change (MoEF&CC). EADA is responsible for the overall management of the environmental audit framework in India.</p>
                        <p>The framework strengthens compliance with major environmental legislations, supporting regulatory approvals such as Environmental Clearance (EC) and Consent to Operate (CTO) via a robust auditing infrastructure.</p>
                        <a href="#" class="about-btn">Read More</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 4rem;">
                <div>
                    <h3 class="serif" style="font-size: 1.75rem; margin-bottom: 1.5rem;">EADA Portal</h3>
                    <p style="opacity: 0.7; max-width: 500px; font-size: 0.95rem;">Empowered oversight for a sustainable nation. EADA is an initiative of the Ministry of Environment, Forest and Climate Change, India.</p>
                </div>
                <div style="text-align: right;">
                    <h4 style="margin-bottom: 1.5rem;">Support</h4>
                    <p style="opacity: 0.7; font-size: 0.9rem;">helpdesk&#64;eada.gov.in</p>
                </div>
            </div>
            <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.85rem; opacity: 0.5; text-align: center;">
                &copy; 2026 Environment Audit Designated Agency. All Rights Reserved.
            </div>
        </div>
    </footer>

</body>
</html>